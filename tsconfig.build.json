{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "paths": {
    "*": ["./*"],
    "@/*": ["./src/*"]
  },
  "include": [
    "src/components/*/*.tsx",
    "src/lib/**/*.tsx", 
    "src/lib/utils.ts"
  ],
  "exclude": ["dist", "node_modules", "src/components/*/*.stories.tsx", "src/components/portfolio/*"]
}
