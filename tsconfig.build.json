{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "paths": {
    "*": ["./*"],
    "@/*": ["./src/*"]
  },
  "include": [
    "src/components/*/index.ts",
    "src/lib/*/index.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
