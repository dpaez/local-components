{
  "name": "local-components",
  "version": "0.1.0-alpha.12",
  "description": "A curated React component library designed for personal sites and portfolio pages",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "NODE_ENV=production bun run build.ts",
    "lint": "NAPI_RS_FORCE_WASI=1 oxlint -c oxlint.json src/",
    "lint:fix": "NAPI_RS_FORCE_WASI=1 oxlint -c oxlint.json src/ --fix",
    "format": "oxfmt -c oxfmt.json src/",
    "format:check": "oxfmt -c oxfmt.json --check src/",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "prepare": "bun .husky/install.mjs",
    "prepublishOnly": "bun run build:lib",
    "build:lib": "NODE_ENV=production bun run build-lib.ts"
  },
  "exports": {
    "./button": {
      "import": "./dist/components/button/button.js",
      "types": "./dist/components/button/button.d.ts"
    },
    "./hero": {
      "import": "./dist/components/hero/hero.js",
      "types": "./dist/components/hero/hero.d.ts"
    },
    "./layout": {
      "import": "./dist/components/layout/layout.js",
      "types": "./dist/components/layout/layout.d.ts"
    },
    "./toggle": {
      "import": "./dist/components/toggle/toggle.js",
      "types": "./dist/components/toggle/toggle.d.ts"
    },
    "./badge": {
      "import": "./dist/components/badge/badge.js",
      "types": "./dist/components/badge/badge.d.ts"
    },
    "./card": {
      "import": "./dist/components/card/card.js",
      "types": "./dist/components/card/card.d.ts"
    },
    "./section": {
      "import": "./dist/components/section/section.js",
      "types": "./dist/components/section/section.d.ts"
    },
    "./typography/heading": {
      "import": "./dist/components/typography/heading.js",
      "types": "./dist/components/typography/heading.d.ts"
    },
    "./typography/text": {
      "import": "./dist/components/typography/text.js",
      "types": "./dist/components/typography/text.d.ts"
    },
    "./typography/lead": {
      "import": "./dist/components/typography/lead.js",
      "types": "./dist/components/typography/lead.d.ts"
    },
    "./typography/blockquote": {
      "import": "./dist/components/typography/blockquote.js",
      "types": "./dist/components/typography/blockquote.d.ts"
    },
    "./typography/code": {
      "import": "./dist/components/typography/code.js",
      "types": "./dist/components/typography/code.d.ts"
    },
    "./theme-context": {
      "import": "./dist/lib/theme-context/index.js",
      "types": "./dist/lib/theme-context/index.d.ts"
    },
    "./utils": {
      "import": "./dist/lib/utils.js",
      "types": "./dist/lib/utils.d.ts"
    },
    "./styles/globals.css": "./dist/styles/globals.css",
    "./styles/tokens.css": "./dist/styles/tokens.css"
  },
  "peerDependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@toolwind/corner-shape": "^0.0.8-3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@storybook/addon-themes": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@tailwindcss/vite": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260311.1",
    "bun-plugin-tailwind": "^0.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "lucide-react": "^0.545.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.53.0",
    "oxlint-tsgolint": "^0.15.0",
    "storybook": "^10.2.17",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dpaez/local-components.git"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwind",
    "typescript",
    "personal-site",
    "portfolio"
  ],
  "license": "MIT",
  "lint-staged": {
    "*.{js,ts,jsx,tsx,mjs,astro,json}": "bun lint:fix"
  }
}